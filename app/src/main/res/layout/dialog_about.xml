<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="28dp"
    android:background="@color/bg_card">

    <androidx.cardview.widget.CardView
        android:layout_width="88dp"
        android:layout_height="88dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="6dp"
        android:layout_marginBottom="16dp">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@mipmap/ic_launcher"
            android:scaleType="centerCrop" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvAboutAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="22sp"
        android:textColor="@color/neon_cyan"
        android:fontFamily="sans-serif-bold"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tvAboutVersion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/btn_func"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Temel aritmetik işlemleri hızlı ve kolay yapmanızı sağlayan modern bir hesap makinesi uygulaması."
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="20dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/btn_func"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Geliştirici"
        android:textSize="11sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Arif Onur Bütün"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TA4AB"
        android:textSize="13sp"
        android:textColor="@color/neon_cyan"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnAboutClose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kapat"
        android:textColor="@color/text_equals"
        android:backgroundTint="@color/neon_cyan"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        style="@style/Widget.MaterialComponents.Button" />

</LinearLayout>
